# BeydounTech — Staging environment template
# Copy to the staging server as `.env` and replace all CHANGE_ME values.
# Do NOT commit a filled-in `.env` to git.

APP_NAME=BeydounTech
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

ALLOW_PUBLIC_REGISTRATION=false
DEMO_ROUTES_ENABLED=false

LOG_CHANNEL=stack
LOG_LEVEL=info

# --------------------
# Database
# --------------------
DB_CONNECTION=mysql
DB_HOST=CHANGE_ME
DB_PORT=3306
DB_DATABASE=CHANGE_ME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# --------------------
# Cache / Session / Queue
# --------------------
CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Real SMTP — required for 2FA OTP, staff invite, password reset QA
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --------------------
# Real-time chat (Laravel Reverb — the mobile app's socket server)
# --------------------
# CHANGE_ME: generate with `php artisan reverb:install` on the server, or copy
# the values it writes to that server's own .env. Give REVERB_APP_KEY + REVERB_HOST
# + REVERB_PORT to the mobile team (they do not need REVERB_APP_SECRET).
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=CHANGE_ME
REVERB_APP_KEY=CHANGE_ME
REVERB_APP_SECRET=CHANGE_ME
REVERB_HOST=beydountech.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# --------------------
# Communications integrations
# --------------------
COMMUNICATIONS_QUEUE_OWNER=Ali
COMMUNICATION_EMAIL_DRIVER=google
COMMUNICATION_SMS_DRIVER=ringcentral
COMMUNICATION_FAX_DRIVER=ringcentral
COMMUNICATIONS_AI_DRIVER=local
COMMUNICATIONS_WEBHOOK_SECRET=CHANGE_ME
COMMUNICATIONS_INBOUND_ORGANIZATION_ID=
OPENAI_API_KEY=
COMMUNICATIONS_AI_MODEL=gpt-4o-mini

RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
RETELL_WEBHOOK_SECRET=

RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_JWT=
RINGCENTRAL_EXTENSION=
RINGCENTRAL_FROM_NUMBER=

GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DELEGATED_USER=
GOOGLE_WORKSPACE_REFRESH_TOKEN=
