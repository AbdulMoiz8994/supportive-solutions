APP_NAME=Tailadmin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ALLOW_PUBLIC_REGISTRATION=false

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tailadmin_laravel
DB_USERNAME=root
DB_PASSWORD=

# Broadcasting (real-time chat sockets). Default "log" is safe everywhere.
# Set to "reverb" once the self-hosted Reverb websocket server is running.
BROADCAST_CONNECTION=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# TailAdmin demo/template pages (Super Admin only when false)
DEMO_ROUTES_ENABLED=false

# Two-Factor Authentication
# Master switch. Set false ONLY for local/dev testing to skip the OTP and log in
# with just email + password. Keep TRUE anywhere holding real data.
TWO_FACTOR_ENFORCED=true
# Optional comma-separated list of emails that skip 2FA while it stays enforced for
# everyone else (throwaway test logins only). e.g. TWO_FACTOR_EXEMPT_EMAILS=qa@example.com
TWO_FACTOR_EXEMPT_EMAILS=

# Mail — required for staging QA of 2FA OTP, staff invites, and password reset (see SERVER_SETUP_GUIDE.md)
# Local: Mailpit on 1025. Staging/production: use real SMTP and verify MAIL_FROM_*.

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Laravel Reverb — self-hosted websocket server for the mobile chat sockets.
# Deploy step: `composer require laravel/reverb && php artisan reverb:install`,
# then run `php artisan reverb:start` under supervisor and set BROADCAST_CONNECTION=reverb.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST="0.0.0.0"
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Availity, AccountantsWorld, and HHA integration settings are managed in
# Global Settings → Credential Vault (encrypted). Values below are optional fallbacks for local/dev bootstrap only.

# Availity — billing claims (OAuth 2.0 client_credentials)
# AVAILITY_ENV=demo
# AVAILITY_APP_ID=
# AVAILITY_DEMO_KEY=
# AVAILITY_DEMO_SECRET=
# AVAILITY_PROD_KEY=
# AVAILITY_PROD_SECRET=
# AVAILITY_TOKEN_URL=https://api.availity.com/v1/token
# AVAILITY_API_BASE_URL=https://api.availity.com/availity/v1
# AVAILITY_SCOPE_DEMO="healthcare-hipaa-transactions-demo healthcare-hipaa-transactions-demo-demo"
# AVAILITY_SCOPE_PROD=healthcare-hipaa-transactions
# AVAILITY_REQUEST_TYPE=PRE_DETERMINATION
# AVAILITY_DEFAULT_PAYER_ID=
# AVAILITY_DEFAULT_DIAGNOSIS_CODE=Z748
# AVAILITY_PLACE_OF_SERVICE=12
# AVAILITY_PATIENT_RELATIONSHIP=18
# AVAILITY_TOKEN_CACHE_SECONDS=240
# AVAILITY_TIMEOUT=30

# DHS Home Help billing (Sigma / ASW email fallback)
# BILLING_DEFAULT_ASW_EMAIL=
# BILLING_SIGMA_PORTAL_URL=https://www.michigan.gov/mdhhs

# Per-sender communication send throttle. A monthly billing cycle emails every
# eligible claim for an org back-to-back under one automation actor, so this
# must stay above the largest org's per-cycle claim count or real cycles will
# get "too many send attempts" failures. Default (200/60s) covers current volumes.
# COMMUNICATION_SEND_RATE_LIMIT_MAX_ATTEMPTS=200
# COMMUNICATION_SEND_RATE_LIMIT_DECAY_SECONDS=60

# AccountantsWorld payroll integration (Payroll Relief API)
# ACCOUNTANTSWORLD_URL=https://www.accountantsworld.com
# ACCOUNTANTSWORLD_API_URL=https://dev-api.payrollrelief.com/integration
# ACCOUNTANTSWORLD_APP_ID=          # x-api-key — used when auth mode is api_key or both
# ACCOUNTANTSWORLD_AUTH_MODE=api_key # api_key | oauth | both
# ACCOUNTANTSWORLD_OAUTH_CLIENT_ID=
# ACCOUNTANTSWORLD_OAUTH_CLIENT_SECRET=
# ACCOUNTANTSWORLD_OAUTH_TOKEN_URL=https://dev-auth.accountantsoffice.com/connect/token
# ACCOUNTANTSWORLD_OAUTH_SCOPE=payroll_api
# ACCOUNTANTSWORLD_PAY_SCHEDULE_ID= # Optional — uses first employee schedule from GET /payroll/PaySchedules if unset
# ACCOUNTANTSWORLD_DEFAULT_PAY_TYPE_CODE=REG
# PAYROLL_ACCOUNTANT_EMAIL=         # e.g. payroll@supportivesolutionshomecare.com
# ACCOUNTANTSWORLD_TIMEOUT=30

# HHAeXchange EVV Aggregator (Phase 1 Implementation / Production)
# HHA_ENVIRONMENT=implementation
# HHA_API_URL=https://implementation.hhaexchange.com
# HHA_TOKEN_URL=https://implementation.hhaexchange.com/identity/connect/token
# HHA_CLIENT_ID=
# HHA_CLIENT_SECRET=
# HHA_SCOPE=write:aggregator
# HHA_ATTESTATION_STATUS=pending
# HHA_PROVIDER_TAX_ID=
# HHA_OFFICE_NPI=
# HHA_PAYER_ID=
# HHA_TOKEN_CACHE_SECONDS=1500
# HHA_TIMEOUT=30
# HHA_VISITS_PATH=/api/v2/visits
# HHA_CAREGIVERS_PATH=/api/v2/caregivers
# HHA_TRANSACTIONS_PATH=/api/v2/visits/transactions

# Google Workspace (Gmail API) — outbound email + AI email intake.
# OAuth refresh-token flow: the app derives fresh access tokens from the refresh token.
# GOOGLE_WORKSPACE_CLIENT_ID=          # OAuth client ID (....apps.googleusercontent.com)
# GOOGLE_WORKSPACE_CLIENT_SECRET=      # OAuth client secret (GOCSPX-...)
# GOOGLE_WORKSPACE_REFRESH_TOKEN=      # long-lived refresh token for the mailbox below
# GOOGLE_WORKSPACE_DELEGATED_USER=     # mailbox address, e.g. info@supportivesolutionshomecare.com
# GOOGLE_WORKSPACE_TIMEOUT=30
