{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:watch": "vite build --watch",
        "test": "node scripts/run-tests.mjs",
        "test:run": "php artisan config:clear && php artisan test --testsuite=ModuleFeatures",
        "test:modules": "php artisan test --testsuite=Modules",
        "test:settings": "php artisan test --testsuite=Settings",
        "test:directory": "php artisan test --testsuite=Directory",
        "test:communication": "php artisan test --testsuite=Communication",
        "test:integrations": "php artisan test --testsuite=Integrations",
        "test:php": "php artisan config:clear && php artisan test",
        "test:php:all": "node scripts/run-tests.mjs --php-only",
        "test:e2e": "npx playwright test --project=chromium",
        "test:e2e:all-browsers": "npx playwright test",
        "test:e2e:legacy": "node tests/e2e/fix-verification.cjs",
        "test:e2e:dashboard-modules": "node tests/e2e/dashboard-modules.cjs",
        "playwright:install": "npx playwright install chromium firefox webkit",
        "playwright:report": "npx playwright show-report playwright-report",
        "test:e2e:setup": "npm run playwright:install && npm run test:e2e",
        "test:all": "node scripts/run-tests.mjs",
        "test:seed": "php artisan migrate:fresh --seed --seeder=E2eTestSeeder --force",
        "test:dashboard-modules": "php artisan test tests/Feature/Modules/VisitReportsModuleTest.php tests/Feature/Modules/TasksModuleTest.php tests/Feature/Modules/TasksBoardUiTest.php tests/Feature/Modules/TasksDragDropAndDrawerTest.php tests/Feature/Modules/FormsModuleTest.php tests/Feature/Modules/DataExplorationModuleTest.php tests/Feature/Modules/DashboardModulesIntegrationTest.php tests/Feature/Navigation/SidebarNavigationTest.php",
        "test:tasks": "php artisan test tests/Feature/Modules/TasksModuleTest.php tests/Feature/Modules/TasksBoardUiTest.php tests/Feature/Modules/TasksDragDropAndDrawerTest.php"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.1.12",
        "@types/node": "^22.10.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^1.1.1",
        "playwright": "^1.61.1",
        "tailwindcss": "^4.1.12",
        "vite": "^5.2.0"
    },
    "dependencies": {
        "@floating-ui/dom": "^1.7.4",
        "@fullcalendar/core": "^6.1.19",
        "@fullcalendar/daygrid": "^6.1.19",
        "@fullcalendar/interaction": "^6.1.19",
        "@fullcalendar/list": "^6.1.19",
        "@fullcalendar/timegrid": "^6.1.19",
        "@popperjs/core": "^2.11.8",
        "alpinejs": "^3.14.9",
        "apexcharts": "^5.3.5",
        "flatpickr": "^4.6.13",
        "jquery": "^3.7.1",
        "jsvectormap": "^1.7.0",
        "prismjs": "^1.30.0",
        "select2": "^4.1.0",
        "swiper": "^12.0.3",
        "toastr": "^2.1.4"
    }
}
